{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "async": false,
            "timeout": 5,
            "command": "P=$(cat \"$HOME/.codex/ac2/hook.port\" 2>/dev/null); [ -n \"$P\" ] && curl -sS -m 2 -X POST --data-binary @- \"http://127.0.0.1:$P/hook\" >/dev/null 2>&1; exit 0"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "async": false,
            "timeout": 5,
            "command": "P=$(cat \"$HOME/.codex/ac2/hook.port\" 2>/dev/null); [ -n \"$P\" ] && curl -sS -m 2 -X POST --data-binary @- \"http://127.0.0.1:$P/hook\" 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "async": false,
            "timeout": 5,
            "command": "P=$(cat \"$HOME/.codex/ac2/hook.port\" 2>/dev/null); [ -n \"$P\" ] && curl -sS -m 2 -X POST --data-binary @- \"http://127.0.0.1:$P/hook\" >/dev/null 2>&1; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "async": false,
            "timeout": 5,
            "command": "P=$(cat \"$HOME/.codex/ac2/hook.port\" 2>/dev/null); [ -n \"$P\" ] && curl -sS -m 2 -X POST --data-binary @- \"http://127.0.0.1:$P/hook\" >/dev/null 2>&1; exit 0"
          }
        ]
      }
    ]
  }
}
